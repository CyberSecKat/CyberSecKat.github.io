source "https://rubygems.org"

# This pins the site to the same Jekyll/plugin versions GitHub Pages uses to
# build the site server-side. You do NOT need Ruby installed locally — GitHub
# builds and deploys automatically on every push to main. This Gemfile only
# matters if you ever want to preview the site locally with `bundle exec jekyll serve`.
gem "github-pages", group: :jekyll_plugins

# Windows/JRuby users need this; harmless everywhere else.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw]
